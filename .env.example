# Copy to .env and fill in. .env is gitignored.

# Parquet data catalog location. Keep this OUTSIDE OneDrive and outside the
# source tree so large/volatile Parquet writes don't get synced or committed.
CATALOG_PATH=C:/nautilus/catalog

# Redis (shared by the trading engine's message bus and the dashboard server)
REDIS_URL=redis://localhost:6379

# Binance API credentials (live/paper). Leave blank for backtest-only.
BINANCE_API_KEY=
BINANCE_API_SECRET=
